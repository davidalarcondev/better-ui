{
  "name": "better-ui-cli",
  "version": "0.3.0",
  "private": false,
  "description": "Open source terminal command center for frontend scanning, review, and safe fixes",
  "main": "dist/src/cli.js",
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ],
  "exports": {
    ".": "./dist/src/cli.js"
  },
  "bin": {
    "better-ui-cli": "bin/better-ui.js"
  },
  "scripts": {
    "scan": "ts-node src/cli.ts /scan",
    "health": "ts-node src/cli.ts /health",
    "doctor": "ts-node src/cli.ts /doctor",
    "a11y": "ts-node src/cli.ts /a11y",
    "build": "node -e \"require('fs').rmSync('dist',{ recursive: true, force: true })\" && tsc",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run",
    "verify": "npm run typecheck && npm run lint && npm run test:ci && npm run build",
    "smoke:commands": "ts-node src/cli.ts /commands",
    "smoke:scan": "ts-node src/cli.ts /scan --format json --out tmp-report.json",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run verify",
    "start": "node ./bin/better-ui.js /commands",
    "better-ui:scan": "better-ui-cli /scan",
    "better-ui:fix": "better-ui-cli /fix --apply",
    "better-ui:health": "better-ui-cli /health",
    "better-ui:doctor": "better-ui-cli /doctor",
    "better-ui:a11y": "better-ui-cli /a11y",
    "better-ui:review": "better-ui-cli /review --changed",
    "better-ui:pr-summary": "better-ui-cli /pr-summary --out pr-summary.md",
    "better-ui:init": "better-ui-cli /init",
    "better-ui:tui": "better-ui-cli /menu"
  },
  "keywords": [
    "frontend",
    "cli",
    "tui",
    "eslint",
    "typescript",
    "a11y",
    "review",
    "open-source"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "eslint": "^10.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "enquirer": "^2.4.1",
    "sharp": "^0.34.5"
  }
}

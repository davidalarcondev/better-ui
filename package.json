    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "eslint": "^10.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "enquirer": "^2.4.1",
    "sharp": "^0.34.5"
  }

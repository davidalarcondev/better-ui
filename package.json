{
  "name": "better-ui",
  "version": "0.2.0",
  "private": true,
  "description": "CLI tool to scan a project and produce frontend improvement reports",
  "main": "dist/bin/doctor.js",
  "bin": {
    "better-ui": "bin/better-ui.js"
  },
  "scripts": {
    "scan": "ts-node src/cli.ts /scan",
    "health": "ts-node src/cli.ts /health",
    "doctor": "ts-node src/cli.ts /doctor",
    "a11y": "ts-node src/cli.ts /a11y",
    "build": "tsc",
    "lint": "eslint .",
